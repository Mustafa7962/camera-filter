<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!--
        This is a custom GLSurfaceView (see CameraFilterEngine.kt / MainActivity.kt).
        CameraX's Preview use case does NOT draw into it directly through PreviewView;
        instead CameraFilterEngine owns a SurfaceTexture/Surface that CameraX writes
        camera frames into, and this view's OpenGL renderer draws that texture to the
        screen after running it through the filter shader.
    -->
    <com.opensource.camfilter.CameraGLSurfaceView
        android:id="@+id/glSurfaceView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Permission / status message shown until camera permission is granted -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:padding="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Camera permission required"
        tools:visibility="visible" />

    <!-- Floating control panel -->
    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_panel"
        android:padding="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Filter mode toggles -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="12dp">

            <ToggleButton
                android:id="@+id/btnFilterNone"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_toggle"
                android:textColor="@color/white"
                android:textOn="@string/filter_none"
                android:textOff="@string/filter_none"
                android:checked="true" />

            <ToggleButton
                android:id="@+id/btnFilterGrayscale"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_toggle"
                android:textColor="@color/white"
                android:textOn="@string/filter_grayscale"
                android:textOff="@string/filter_grayscale" />

            <ToggleButton
                android:id="@+id/btnFilterSepia"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_toggle"
                android:textColor="@color/white"
                android:textOn="@string/filter_sepia"
                android:textOff="@string/filter_sepia" />
        </LinearLayout>

        <!-- Brightness -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_brightness"
            android:textColor="@color/white"
            android:textSize="12sp" />
        <SeekBar
            android:id="@+id/seekBrightness"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="100"
            android:progressTint="@color/accent"
            android:thumbTint="@color/accent" />

        <!-- Contrast -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_contrast"
            android:textColor="@color/white"
            android:textSize="12sp" />
        <SeekBar
            android:id="@+id/seekContrast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="100"
            android:progressTint="@color/accent"
            android:thumbTint="@color/accent" />

        <!-- Skin smoothing -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_smoothing"
            android:textColor="@color/white"
            android:textSize="12sp" />
        <SeekBar
            android:id="@+id/seekSmoothing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/accent"
            android:thumbTint="@color/accent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/btn_overlay_start"
            app:backgroundTint="@color/accent" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
